# Google Sheets Configuration
# The Web App URL generated when deploying your Apps Script Web App (from .script.gs / Code.gs)
GOOGLE_SHEET_WEBHOOK_URL=""

# Resend Email Configuration
# API key from your Resend dashboard (https://resend.com)
RESEND_API_KEY=""

# The verified sender email address configured in Resend (defaults to Resend's free tier sender)
FROM_EMAIL="onboarding@resend.dev"

# Comma-separated list of admin email addresses to receive rate limit alerts
NOTIFICATION_EMAILS=""

# ImgBB Configuration
# API key from your ImgBB account (https://api.imgbb.com) to host uploaded payment receipts
IMGBB_API_KEY=""
